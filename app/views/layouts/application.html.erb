<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg bg-light">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Travel Journal</a>

        <div>
          <a href="/" class="btn btn-outline-primary me-2">Home</a>

          <% if current_user %>
            <span class="me-2">Logged in as: <%= current_user["username"] %></span>
            <a href="/logout" class="btn btn-outline-danger">Logout</a>
          <% else %>
            <a href="/login" class="btn btn-outline-success me-2">Login</a>
            <a href="/users/new" class="btn btn-outline-secondary">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <div>
        <%= flash["notice"] %>
      </div>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>